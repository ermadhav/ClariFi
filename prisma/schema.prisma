// ClariFi - Complete Database Schema for Indian Portfolio Tracker
// PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH MODELS (NextAuth.js compatible)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  image         String?
  panNumber     String?   @unique
  dateOfBirth   DateTime?
  riskAppetite  RiskAppetite @default(MODERATE)
  isOnboarded   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  holdings       Holding[]
  transactions   Transaction[]
  watchlists     Watchlist[]
  alerts         Alert[]
  dividends      Dividend[]
  capitalGains   CapitalGain[]
  mutualFunds    MutualFund[]
  brokerAccounts BrokerAccount[]
  positions      Position[]
  orders         Order[]
  funds          Fund[]
  goals          UserGoal[]
  subscription   Subscription?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PORTFOLIO MODELS
// ============================================

model Holding {
  id             String   @id @default(cuid())
  userId         String
  stockSymbol    String   // format "NSE:RELIANCE"
  symbol         String?  // old field, keep for compat or remove? Let's just use the fields
  exchange       Exchange @default(NSE)
  companyName    String
  sector         String?
  industry       String?
  marketCap      MarketCapType?
  quantity       Int
  averagePrice   Float
  currentPrice   Float    @default(0)
  totalInvested  Float?
  currentValue   Float    @default(0)
  pnl            Float    @default(0)
  pnlPercent     Float    @default(0)
  dayChange      Float    @default(0)
  dayChangePercent Float  @default(0)
  weight         Float    @default(0)
  pe             Float    @default(0)
  pb             Float    @default(0)
  dividendYield  Float    @default(0)
  beta           Float    @default(1)
  high52w        Float    @default(0)
  low52w         Float    @default(0)
  volume         Int      @default(0)
  firstBoughtDate DateTime?
  brokerId       String?
  lastUpdated    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker       BrokerAccount? @relation(fields: [brokerId], references: [id])
  transactions Transaction[]

  @@unique([userId, stockSymbol, brokerId])
  @@index([userId])
  @@map("holdings")
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  holdingId     String?
  symbol        String
  exchange      Exchange        @default(NSE)
  companyName   String
  type          TransactionType
  quantity      Int
  pricePerShare Float
  totalAmount   Float
  brokerage     Float           @default(0)
  stt           Float           @default(0)
  gst           Float           @default(0)
  stampDuty     Float           @default(0)
  otherCharges  Float           @default(0)
  totalCharges  Float           @default(0)
  netAmount     Float
  broker        String
  orderId       String?
  date          DateTime
  notes         String?
  createdAt     DateTime        @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holding Holding? @relation(fields: [holdingId], references: [id])

  @@index([userId])
  @@index([userId, symbol])
  @@index([date])
  @@map("transactions")
}

model Position {
  id             String   @id @default(cuid())
  userId         String
  brokerId       String?
  symbol         String
  exchange       Exchange @default(NSE)
  product        String?  // e.g., INTRADAY, DELIVERY, MARGIN
  quantity       Int
  averagePrice   Float
  currentPrice   Float    @default(0)
  pnl            Float    @default(0)
  pnlPercent     Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker       BrokerAccount? @relation(fields: [brokerId], references: [id])

  @@unique([userId, symbol, brokerId, product])
  @@index([userId])
  @@map("positions")
}

model Order {
  id             String   @id @default(cuid())
  orderId        String   // Broker's order ID
  userId         String
  brokerId       String?
  symbol         String
  exchange       Exchange @default(NSE)
  type           TransactionType
  quantity       Int
  price          Float
  status         String   // e.g., COMPLETE, REJECTED, CANCELLED
  timestamp      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker       BrokerAccount? @relation(fields: [brokerId], references: [id])

  @@unique([userId, orderId, brokerId])
  @@index([userId])
  @@map("orders")
}

model Fund {
  id             String   @id @default(cuid())
  userId         String
  brokerId       String?
  availableMargin Float   @default(0)
  usedMargin     Float    @default(0)
  totalBalance   Float    @default(0)
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker       BrokerAccount? @relation(fields: [brokerId], references: [id])

  @@unique([userId, brokerId])
  @@index([userId])
  @@map("funds")
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  color     String          @default("#6366f1")
  stocks    WatchlistStock[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("watchlists")
}

model WatchlistStock {
  id          String   @id @default(cuid())
  watchlistId String
  symbol      String
  exchange    Exchange @default(NSE)
  addedAt     DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol, exchange])
  @@map("watchlist_stocks")
}

model Alert {
  id          String    @id @default(cuid())
  userId      String
  symbol      String
  companyName String
  type        AlertType
  condition   String
  targetValue Float?
  isActive    Boolean   @default(true)
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("alerts")
}

model Dividend {
  id               String   @id @default(cuid())
  userId           String
  symbol           String
  companyName      String
  exDate           DateTime
  recordDate       DateTime?
  paymentDate      DateTime?
  dividendPerShare Float
  quantityHeld     Int
  totalDividend    Float
  tdsDeducted      Float    @default(0)
  netAmount        Float
  financialYear    String
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([financialYear])
  @@map("dividends")
}

model CapitalGain {
  id            String          @id @default(cuid())
  userId        String
  symbol        String
  companyName   String
  type          CapitalGainType
  buyDate       DateTime
  sellDate      DateTime
  quantity      Int
  buyPrice      Float
  sellPrice     Float
  gain          Float
  tax           Float
  financialYear String
  holdingPeriod Int             // days
  createdAt     DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([financialYear])
  @@map("capital_gains")
}

model MutualFund {
  id            String   @id @default(cuid())
  userId        String
  fundName      String
  amcCode       String
  schemeCode    String
  category      String
  amc           String
  folioNumber   String?
  units         Float
  nav           Float    @default(0)
  invested      Float
  currentValue  Float    @default(0)
  pnl           Float    @default(0)
  xirr          Float    @default(0)
  sipAmount     Float?
  sipDate       Int?     // day of month
  expenseRatio  Float    @default(0)
  rating        Int      @default(3) // 1-5
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mutual_funds")
}

// ============================================
// BROKER INTEGRATION
// ============================================

model BrokerAccount {
  id             String       @id @default(cuid())
  userId         String
  brokerName     BrokerType
  clientId       String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  isConnected    Boolean      @default(true)
  lastSynced     DateTime?
  syncStatus     SyncStatus   @default(PENDING)
  metadata       Json?        // broker-specific data
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brokerName])
  @@map("broker_accounts")

  holdings       Holding[]
  positions      Position[]
  orders         Order[]
  funds          Fund[]
}

model BrokerAuthState {
  id        String   @id @default(cuid())
  userId    String
  state     String   @unique
  broker    BrokerType
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("broker_auth_states")
}

// ============================================
// SUBSCRIPTION & GOALS
// ============================================

model Subscription {
  id        String           @id @default(cuid())
  userId    String           @unique
  plan      SubscriptionPlan @default(FREE)
  startDate DateTime         @default(now())
  endDate   DateTime?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UserGoal {
  id         String   @id @default(cuid())
  userId     String
  goalType   GoalType
  targetAmount Float?
  targetDate DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

// ============================================
// MARKET DATA CACHE
// ============================================

model StockPrice {
  id        String   @id @default(cuid())
  symbol    String
  exchange  Exchange @default(NSE)
  price     Float
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    Int?
  change    Float?
  changePct Float?
  high52w   Float?
  low52w    Float?
  marketCap Float?
  pe        Float?
  pb        Float?
  updatedAt DateTime @default(now())

  @@unique([symbol, exchange])
  @@index([symbol])
  @@map("stock_prices")
}

// ============================================
// ENUMS
// ============================================

enum RiskAppetite {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum Exchange {
  NSE
  BSE
}

enum MarketCapType {
  LARGE_CAP
  MID_CAP
  SMALL_CAP
  MICRO_CAP
}

enum TransactionType {
  BUY
  SELL
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  PERCENT_CHANGE
  VOLUME_SPIKE
  CUSTOM
}

enum CapitalGainType {
  STCG
  LTCG
}

enum BrokerType {
  ZERODHA
  ANGEL_ONE
  UPSTOX
  DHAN
  FIVE_PAISA
  GROWW
  MANUAL
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum GoalType {
  WEALTH_CREATION
  RETIREMENT
  SHORT_TERM
  DIVIDEND_INCOME
  TAX_SAVING
  EDUCATION
  HOUSE
  EMERGENCY_FUND
}
